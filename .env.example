# ── Database (Neon Serverless Postgres) ───────────────────────────
DATABASE_URL="postgresql://USER:PASS@HOST-pooler.neon.tech/DB?sslmode=require&pgbouncer=true&connect_timeout=30"
DATABASE_URL_UNPOOLED="postgresql://USER:PASS@HOST.neon.tech/DB?sslmode=require"

# ── Queue (Upstash Redis TLS) ─────────────────────────────────────
REDIS_URL="rediss://default:PASSWORD@HOST.upstash.io:6379"

# ── Qwen Cloud (DashScope International) ──────────────────────────
QWEN_API_KEY="sk-..."
QWEN_BASE_URL="https://dashscope-intl.aliyuncs.com/compatible-mode/v1"

# ── Email — outbound (Resend) ─────────────────────────────────────
RESEND_API_KEY="re_..."
FROM_EMAIL="sales@yourdomain.com"

# ── Email — inbound (IMAP polling) ───────────────────────────────
IMAP_HOST="imap.gmail.com"
IMAP_PORT=993
IMAP_USER="sales@yourdomain.com"
IMAP_PASS="your-app-password"

# ── Auth ──────────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
DEMO_PASSWORD="demo"

# ── Internal services ─────────────────────────────────────────────
MCP_SERVER_URL="http://localhost:4001"
MCP_API_KEY="change-me-in-production"
JWT_SECRET="change-me-in-production"

# ── Agent config ──────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.8
FOLLOWUP_DELAY_DAYS=2
FOLLOWUP_MAX_COUNT=2

# ── Frontend public URLs (used by Next.js) ────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ── Alibaba Cloud deployment ──────────────────────────────────────
# Set HOST_IP to your SAS/ECS public IP when running docker-compose.alibaba.yml
# HOST_IP=1.2.3.4
