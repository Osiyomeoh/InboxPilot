# Database
DATABASE_URL="postgresql://inbox:inbox@localhost:5432/inboxpilot"

# Redis
REDIS_URL="redis://localhost:6379"

# Qwen Cloud
QWEN_API_KEY="sk-..."
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# Email — IMAP polling
IMAP_HOST="imap.gmail.com"
IMAP_PORT=993
IMAP_USER="sales@company.com"
IMAP_PASS="app-password"

# Email — outbound (Resend)
RESEND_API_KEY="re_..."
RESEND_WEBHOOK_SECRET="whsec_..."
FROM_EMAIL="sales@company.com"

# Auth
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"
GITHUB_CLIENT_ID="..."
GITHUB_CLIENT_SECRET="..."

# Internal services
MCP_SERVER_URL="http://localhost:4001"
MCP_API_KEY="internal-secret"
API_URL="http://localhost:3001"
API_WS_URL="ws://localhost:3001"
JWT_SECRET="change-me-in-production"

# PDF output
PDF_OUTPUT_DIR="/tmp/inbox-pilot/pdfs"

# Confidence threshold for auto-send vs human review (0-1)
CONFIDENCE_THRESHOLD=0.8

# Follow-up config
FOLLOWUP_DELAY_DAYS=2
FOLLOWUP_MAX_COUNT=2
